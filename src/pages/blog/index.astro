---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BaseLayout
  title="Blog | Sunshine Tiny Houses"
  description="Tiny house tips, design inspiration, council updates and news from the Sunshine Tiny Houses team in Noosaville, QLD."
  canonical="https://www.sunshinetinyhouses.com.au/blog/"
>

  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Blog</p>
      <h1>News &amp; Insights</h1>
      <p class="page-hero__sub">Council updates, design ideas, and everything you need to know about building on the Sunshine Coast.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="post-grid">
        {posts.map((post) => {
          const date = post.data.publishDate.toLocaleDateString('en-AU', {
            day: 'numeric', month: 'long', year: 'numeric'
          });
          return (
            <a href={`/blog/${post.id}/`} class="post-card">
              {post.data.heroImage && (
                <div class="post-card__img-wrap">
                  <img
                    src={post.data.heroImage}
                    alt={post.data.heroImageAlt ?? post.data.title}
                    class="post-card__img"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="post-card__body">
                <p class="post-card__meta">{post.data.author} · <time>{date}</time></p>
                <h2 class="post-card__title">{post.data.title}</h2>
                <p class="post-card__desc">{post.data.description}</p>
                <span class="post-card__cta">Read more →</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.page-hero {
  background: var(--color-surface-dark);
  color: #fff;
  padding: 4rem 0 3rem;
}
.page-hero h1 { color: #fff; }
.page-hero__sub { color: rgba(255,255,255,.7); margin-top: .75rem; font-size: 1.1rem; }

.post-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 2rem;
}

.post-card {
  display: flex;
  flex-direction: column;
  background: #fff;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-card);
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  transition: box-shadow .2s, transform .15s;
}
.post-card:hover {
  box-shadow: 0 8px 24px rgba(0,0,0,.08);
  transform: translateY(-3px);
}

.post-card__img-wrap {
  width: 100%;
  height: 220px;
  overflow: hidden;
}
.post-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform .3s;
}
.post-card:hover .post-card__img { transform: scale(1.03); }

.post-card__body {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  flex: 1;
}
.post-card__meta {
  font-size: var(--font-size-xs, 0.8rem);
  color: var(--color-text-muted);
  margin: 0;
}
.post-card__title {
  font-size: var(--font-size-lg);
  line-height: 1.3;
  margin: 0;
  color: var(--color-text);
}
.post-card__desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-body);
  line-height: 1.6;
  margin: 0;
  flex: 1;
}
.post-card__cta {
  font-size: var(--font-size-sm);
  font-weight: 700;
  color: var(--color-primary);
  margin-top: 0.5rem;
}
</style>
