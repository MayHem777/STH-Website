---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getCollection } from 'astro:content';

const allProducts = (await getCollection('products-modular', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const standaloneCards = allProducts
  .filter((p) => !p.data.bedrooms)
  .map((p) => ({
    id: p.id,
    order: p.data.order,
    title: p.data.title,
    description: p.data.description,
    href: `/modular-homes/${p.id}/`,
    heroImage: p.data.heroImage,
    heroImageAlt: p.data.heroImageAlt ?? p.data.title,
    badge: p.data.badge,
  }));

const bedroomCounts = [...new Set(allProducts.filter((p) => p.data.bedrooms).map((p) => p.data.bedrooms))].sort();
const bedroomCards = bedroomCounts.map((count) => {
  const variants = allProducts.filter((p) => p.data.bedrooms === count);
  return {
    id: `${count}-bedroom`,
    order: Math.min(...variants.map((p) => p.data.order)),
    title: `${count} Bedroom`,
    description: `${variants.length} model${variants.length === 1 ? '' : 's'}: ${variants.map((p) => p.data.title).join(', ')}`,
    href: `/modular-homes/${count}-bedroom/`,
    heroImage: variants[0].data.heroImage,
    heroImageAlt: variants[0].data.heroImageAlt ?? `${count} bedroom modular home`,
    badge: undefined,
  };
});

const products = [...standaloneCards, ...bedroomCards].sort((a, b) => a.order - b.order);
---

<BaseLayout
  title="Modular Homes & Granny Flats QLD | Sunshine Tiny Houses"
  description="QBCC-licensed modular homes and granny flats built and delivered across Queensland. Class 1a compliant, finance available. Free quote from Noosaville QLD."
>

  <Hero
    title="Modular Homes & Granny Flats"
    subtitle="Permanent Class 1a modular structures delivered and installed in one week. Perfect as a granny flat, secondary dwelling, or standalone home."
    ctaText="Contact Now"
    ctaHref="/contact/"
    secondaryCtaText="Finance Options"
    secondaryCtaHref="/finance/"
  />

  <section class="section">
    <div class="container">
      <div class="products-grid">
        {products.map((p) => (
          <ProductCard
            title={p.title}
            description={p.description}
            href={p.href}
            image={p.heroImage}
            imageAlt={p.heroImageAlt}
            badge={p.badge}
          />
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.products-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
}
@media (max-width: 1100px) { .products-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 600px) { .products-grid { grid-template-columns: 1fr; } }
</style>
