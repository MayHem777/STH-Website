---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProductCard from '../components/ProductCard.astro';
import CTAButton from '../components/CTAButton.astro';
import { getCollection } from 'astro:content';

const thowProducts = (await getCollection('products-thow', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const modularProducts = (await getCollection('products-modular', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const class10aProducts = (await getCollection('products-class10a', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Sunshine Tiny Houses | Queensland Tiny Home Builders"
  description="Sunshine Tiny Houses builds tiny homes on wheels, modular homes, and granny flats across Queensland. QBCC licensed. Free quote available."
>

  <Hero
    title="Build Your Dream Tiny Home in Queensland"
    subtitle="Sunshine Tiny Houses is a QBCC-licensed builder crafting quality tiny houses on wheels, modular homes, and backyard studios across Queensland."
    ctaText="Contact Now"
    ctaHref="/contact/"
    secondaryCtaText="View Our Range"
    secondaryCtaHref="/tiny-houses-on-wheels/"
  />

  <!-- Two primary product lines — equal weight -->
  <section class="section product-lines">
    <div class="container">
      <div class="product-lines__grid">

        <div class="product-line-card">
          <h2 class="product-line-card__title">Tiny Houses on Wheels</h2>
          <p class="product-line-card__desc">
            From compact 6m designs to our sprawling 10m Lennox model — fully liveable
            and road-registerable. Perfect for primary residences, holiday homes, or
            investment properties.
          </p>
          <ul class="product-line-card__models" aria-label="THOW models">
            {thowProducts.map((p) => (
              <li>
                <a href={`/tiny-houses-on-wheels/${p.id}/`}>
                  {p.data.title}
                  {p.data.specs?.Length && <span class="model-length">{p.data.specs.Length}</span>}
                </a>
              </li>
            ))}
            <li><a href="/tiny-houses-on-wheels/">View all models &rarr;</a></li>
          </ul>
          <CTAButton href="/tiny-houses-on-wheels/">Explore THOW Range</CTAButton>
        </div>

        <div class="product-line-divider" aria-hidden="true"></div>

        <div class="product-line-card">
          <div class="product-line-card__eyebrow">Class 1a Dwelling</div>
          <h2 class="product-line-card__title">Modular Homes & Granny Flats</h2>
          <p class="product-line-card__desc">
            Permanent modular structures built to last — ideal as granny flats, secondary
            dwellings, or standalone homes. Delivered and installed in one week.
            Finance options available.
          </p>
          <ul class="product-line-card__models" aria-label="Modular models">
            {modularProducts.map((p) => (
              <li>
                <a href={`/modular-homes/${p.id}/`}>{p.data.title}</a>
              </li>
            ))}
            <li><a href="/modular-homes/">View all models &rarr;</a></li>
          </ul>
          <CTAButton href="/modular-homes/">Explore Modular Range</CTAButton>
        </div>

      </div>
    </div>
  </section>

  <!-- Class 10a promo section -->
  <section class="section section--surface class10a-promo">
    <div class="container">
      <div class="class10a-promo__header">
        <div>
          <div class="eyebrow">Class 10a Structures</div>
          <h2>Backyard Studios</h2>
          <p>Not looking for a full home? Our backyard studios are the perfect addition to any property — offices, saunas, and utility rooms built to the same quality standard.</p>
        </div>
        <CTAButton href="/backyard-studios/" variant="secondary">View Studios</CTAButton>
      </div>
      <div class="class10a-grid">
        {class10aProducts.map((p) => (
          <ProductCard
            title={p.data.title}
            description={p.data.description}
            href={`/backyard-studios/${p.id}/`}
            image={p.data.heroImage}
            imageAlt={p.data.heroImageAlt}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="section--sm trust-bar">
    <div class="container">
      <ul class="trust-list" role="list">
        <li>
          <strong>QBCC Licensed</strong>
          <span>#15205110</span>
        </li>
        <li>
          <strong>Queensland Built</strong>
          <span>Noosaville, QLD</span>
        </li>
        <li>
          <strong>Tiny Home Specialists</strong>
          <span>Since 2019</span>
        </li>
        <li>
          <strong>Finance Available</strong>
          <span>Flexible options</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section section--dark cta-section">
    <div class="container cta-section__inner">
      <h2>Ready to start your tiny home journey?</h2>
      <p>Get a free, no-obligation quote from Queensland's trusted tiny home builder.</p>
      <CTAButton href="/contact/" variant="ghost">Contact Now</CTAButton>
    </div>
  </section>

</BaseLayout>

<style>
.product-lines__grid {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: start;
}
.product-line-divider {
  width: 1px;
  background-color: var(--color-border);
  align-self: stretch;
  margin-inline: 3rem;
}
.product-line-card {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding-block: 1rem;
}
.product-line-card__eyebrow {
  font-size: var(--font-size-xs);
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-accent);
}
.product-line-card__title {
  font-size: var(--font-size-3xl);
}
.product-line-card__desc {
  color: var(--color-text-muted);
  line-height: 1.6;
}
.product-line-card__models {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
}
.product-line-card__models a {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: var(--font-size-sm);
  font-weight: 500;
  color: var(--color-text);
  transition: color var(--transition-fast);
}
.product-line-card__models a:hover { color: var(--color-primary); }
.model-length {
  font-size: var(--font-size-xs);
  color: var(--color-text-muted);
  background-color: var(--color-surface);
  padding: 0.125rem 0.375rem;
  border-radius: 2px;
}
.product-line-card__models li:last-child a {
  color: var(--color-primary);
  font-weight: 700;
  margin-top: 0.25rem;
}

.eyebrow {
  font-size: var(--font-size-xs);
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: 0.5rem;
}
.class10a-promo__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 2rem;
  margin-bottom: 2.5rem;
}
.class10a-promo__header h2 { margin-block: 0.375rem 0.75rem; }
.class10a-promo__header p {
  color: var(--color-text-muted);
  max-width: 560px;
  line-height: 1.6;
}
.class10a-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.trust-bar { border-block: 1px solid var(--color-border); }
.trust-list {
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
  gap: 1.5rem;
  list-style: none;
  text-align: center;
}
.trust-list li { display: flex; flex-direction: column; gap: 0.25rem; }
.trust-list strong { font-size: var(--font-size-base); font-family: var(--font-heading); }
.trust-list span { font-size: var(--font-size-sm); color: var(--color-text-muted); }

.cta-section__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 1.25rem;
}
.cta-section__inner h2 { color: var(--color-text-on-dark); }
.cta-section__inner p {
  color: rgba(255,255,255,0.8);
  font-size: var(--font-size-lg);
  max-width: 480px;
}

@media (max-width: 900px) {
  .product-lines__grid { grid-template-columns: 1fr; }
  .product-line-divider {
    width: 100%;
    height: 1px;
    margin-inline: 0;
    margin-block: 2rem;
  }
  .class10a-promo__header { flex-direction: column; align-items: flex-start; }
  .class10a-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 600px) {
  .class10a-grid { grid-template-columns: 1fr; }
}
</style>
