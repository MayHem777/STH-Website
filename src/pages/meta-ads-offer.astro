---
import LandingLayout from '../layouts/LandingLayout.astro';
---

<style is:global>
  @media (max-width: 640px) {
    body { padding-bottom: calc(110px + env(safe-area-inset-bottom)) !important; }
  }

  #sth-meta {
    font-family: 'Outfit', system-ui, sans-serif;
    color: #1A1A1A;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
    width: 100%;
  }
  #sth-meta *, #sth-meta *::before, #sth-meta *::after { box-sizing: border-box; margin: 0; padding: 0; min-width: 0; }
  #sth-meta img { display: block; max-width: 100%; height: auto; }
  #sth-meta a   { color: inherit; text-decoration: none; }

  #sth-meta .m-container { max-width: 680px; margin: 0 auto; padding: 0 1.25rem; }

  #sth-meta .m-btn {
    display: inline-block;
    padding: 1.1rem 2rem;
    border-radius: 8px;
    font-family: 'Outfit', system-ui, sans-serif;
    font-weight: 700;
    font-size: 1.05rem;
    cursor: pointer;
    border: none;
    transition: background .2s, transform .15s, box-shadow .2s;
    line-height: 1.2;
    text-align: center;
  }
  #sth-meta .m-btn-primary { background: #5C6A5B; color: #fff; box-shadow: 0 4px 16px rgba(92,106,91,.4); }
  #sth-meta .m-btn-primary:hover { background: #4A574A; transform: translateY(-2px); }
  #sth-meta .m-btn-full { display: block; width: 100%; }

  #sth-meta .m-form-row { margin-bottom: .75rem; }
  #sth-meta .m-form-row label {
    display: block;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .6px;
    text-transform: uppercase;
    color: #555;
    margin-bottom: .3rem;
    font-family: 'Outfit', system-ui, sans-serif;
  }
  #sth-meta .m-form-row input {
    width: 100%;
    padding: .9rem 1rem;
    border: 1.5px solid #DDD8D0;
    border-radius: 8px;
    font-family: 'Outfit', system-ui, sans-serif;
    font-size: 1rem;
    color: #1A1A1A;
    background: #FAFAF8;
    -webkit-appearance: none;
    appearance: none;
    transition: border-color .18s, box-shadow .18s;
    line-height: 1.4;
  }
  #sth-meta .m-form-row input:focus {
    outline: none;
    border-color: #5C6A5B;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(92,106,91,.12);
  }
  #sth-meta .m-form-row input.m-invalid { border-color: #C0392B; background: #FFF8F7; box-shadow: 0 0 0 3px rgba(192,57,43,.1); }
  #sth-meta .m-field-error { display: none; font-size: .72rem; color: #C0392B; margin-top: .3rem; font-weight: 600; font-family: 'Outfit', system-ui, sans-serif; }
  #sth-meta .m-field-error.m-visible { display: block; }
  #sth-meta .m-privacy { font-size: .7rem; color: #AAA; text-align: center; margin-top: .65rem; font-family: 'Outfit', system-ui, sans-serif; }
  #sth-meta .m-form-success { display: none; text-align: center; padding: 2rem 1rem; }
  #sth-meta .m-form-success .fs-icon { font-size: 2.5rem; margin-bottom: 1rem; display: block; }
  #sth-meta .m-form-success h3 { font-size: 1.15rem; font-weight: 800; margin-bottom: .4rem; color: #1A1A1A; font-family: 'Outfit', system-ui, sans-serif; }
  #sth-meta .m-form-success p { font-size: .9rem; color: #666; line-height: 1.6; font-family: 'Outfit', system-ui, sans-serif; }

  /* ── Hero ── */
  #sth-meta .m-hero {
    position: relative;
    min-height: 75vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  #sth-meta .m-hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/workshop-recent-1.jpeg');
    background-size: cover;
    background-position: center 40%;
  }
  #sth-meta .m-hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.9) 0%, rgba(0,0,0,.55) 50%, rgba(0,0,0,.1) 100%);
  }
  #sth-meta .m-hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: 3rem 1.5rem;
    max-width: 720px;
    margin: 0 auto;
  }
  #sth-meta .m-eyebrow {
    display: inline-block;
    background: rgba(200,169,110,.2);
    border: 1px solid rgba(200,169,110,.5);
    color: #C8A96E;
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: .3rem .9rem;
    border-radius: 999px;
    margin-bottom: 1rem;
    font-family: 'Outfit', system-ui, sans-serif;
  }
  #sth-meta .m-hero h1 {
    font-size: clamp(2rem, 5.5vw, 3rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.12;
    margin-bottom: .9rem;
    letter-spacing: -.3px;
    font-family: 'Outfit', system-ui, sans-serif;
  }
  #sth-meta .m-hero h1 em { font-style: normal; color: #C8A96E; }
  #sth-meta .m-hero-sub {
    font-size: 1rem;
    color: rgba(255,255,255,.82);
    line-height: 1.68;
    margin-bottom: 1.75rem;
    max-width: 520px;
    font-family: 'Outfit', system-ui, sans-serif;
  }
  #sth-meta .m-hero-cta-wrap { display: flex; flex-direction: column; gap: .65rem; align-items: flex-start; }
  #sth-meta .m-hero-reassure { font-size: .78rem; color: rgba(255,255,255,.45); font-family: 'Outfit', system-ui, sans-serif; }

  /* ── Outcomes ── */
  #sth-meta .m-outcomes { background: #F4F0EB; padding: 2rem 1.25rem; }
  #sth-meta .m-outcomes-grid { max-width: 680px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: .85rem; }
  #sth-meta .m-oc { background: #fff; border: 1px solid #DDE2DB; border-radius: 12px; padding: 1.1rem .85rem; text-align: center; }
  #sth-meta .m-oc .oc-icon  { font-size: 1.65rem; display: block; margin-bottom: .4rem; }
  #sth-meta .m-oc .oc-label { font-size: .82rem; font-weight: 700; color: #1A1A1A; line-height: 1.3; font-family: 'Outfit', system-ui, sans-serif; }

  /* ── Gallery ── */
  #sth-meta .m-gallery { padding: 3rem 1.25rem; background: #fff; }
  #sth-meta .m-gallery-intro { text-align: center; margin-bottom: 1.5rem; }
  #sth-meta .m-gallery-intro .m-label { font-size: .72rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #5C6A5B; display: block; margin-bottom: .3rem; font-family: 'Outfit', system-ui, sans-serif; }
  #sth-meta .m-gallery-intro h2 { font-size: clamp(1.35rem, 3vw, 1.8rem); font-weight: 800; color: #1A1A1A; line-height: 1.2; font-family: 'Outfit', system-ui, sans-serif; }
  #sth-meta .m-gallery-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: .75rem; max-width: 680px; margin: 0 auto; }
  #sth-meta .m-gallery-grid figure { margin: 0; border-radius: 10px; overflow: hidden; background: #DDE2DB; }
  #sth-meta .m-gallery-grid img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; }

  /* ── Featured review ── */
  #sth-meta .m-review-featured { background: #5C6A5B; padding: 3rem 1.25rem; }
  #sth-meta .m-review-featured .m-inner { max-width: 680px; margin: 0 auto; }
  #sth-meta .m-stars { color: #C8A96E; font-size: 1rem; letter-spacing: 2px; display: block; margin-bottom: .85rem; }
  #sth-meta .m-review-featured blockquote { font-size: 1.05rem; font-style: italic; line-height: 1.82; color: rgba(255,255,255,.93); margin-bottom: 1.35rem; font-family: 'Outfit', system-ui, sans-serif; }
  #sth-meta .m-rev-meta { display: flex; align-items: center; gap: .65rem; }
  #sth-meta .m-avatar { width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,.18); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: .88rem; color: #fff; flex-shrink: 0; font-family: 'Outfit', system-ui, sans-serif; }
  #sth-meta .m-rev-name   { font-weight: 700; font-size: .88rem; display: block; color: #fff; font-family: 'Outfit', system-ui, sans-serif; white-space: nowrap; }
  #sth-meta .m-rev-detail { font-size: .72rem; color: rgba(255,255,255,.45); display: block; font-family: 'Outfit', system-ui, sans-serif; white-space: nowrap; }

  /* ── Process ── */
  #sth-meta .m-process { padding: 3.5rem 1.25rem; background: #fff; }
  #sth-meta .m-process-intro { text-align: center; margin-bottom: 2.25rem; }
  #sth-meta .m-process-intro .m-label { font-size: .72rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #5C6A5B; display: block; margin-bottom: .3rem; font-family: 'Outfit', system-ui, sans-serif; }
  #sth-meta .m-process-intro h2 { font-size: clamp(1.35rem, 3vw, 1.8rem); font-weight: 800; color: #1A1A1A; line-height: 1.2; font-family: 'Outfit', system-ui, sans-serif; }
  #sth-meta .m-steps { max-width: 560px; margin: 0 auto; display: flex; flex-direction: column; gap: 1.5rem; }
  #sth-meta .m-step { display: flex; gap: 1.1rem; align-items: flex-start; }
  #sth-meta .m-step-num { width: 46px; height: 46px; border-radius: 50%; background: #5C6A5B; color: #fff; font-size: 1.1rem; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-shadow: 0 4px 12px rgba(92,106,91,.3); font-family: 'Outfit', system-ui, sans-serif; }
  #sth-meta .m-step-body h3 { font-size: 1rem; font-weight: 700; margin-bottom: .3rem; color: #1A1A1A; font-family: 'Outfit', system-ui, sans-serif; line-height: 1.3; }
  #sth-meta .m-step-body p  { font-size: .88rem; color: #666; line-height: 1.65; font-family: 'Outfit', system-ui, sans-serif; }

  /* ── Supporting reviews ── */
  #sth-meta .m-reviews2 { background: #F4F0EB; padding: 3rem 1.25rem; }
  #sth-meta .m-reviews2-grid { max-width: 680px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  #sth-meta .m-rev-card { background: #fff; border: 1px solid #DDE2DB; border-radius: 12px; padding: 1.35rem; }
  #sth-meta .m-rev-card blockquote { font-size: .88rem; font-style: italic; color: #444; line-height: 1.72; margin-bottom: 1rem; font-family: 'Outfit', system-ui, sans-serif; }
  #sth-meta .m-rev-card .m-rev-name   { color: #1A1A1A; white-space: nowrap; }
  #sth-meta .m-rev-card .m-rev-detail { color: #999; white-space: nowrap; }
  #sth-meta .m-rev-card .m-avatar { background: #DDE2DB; color: #1A1A1A; }

  /* ── CTA + Form ── */
  #sth-meta .m-cta { background: #1A1A1A; padding: 4rem 1.25rem; }
  #sth-meta .m-cta-inner { max-width: 520px; margin: 0 auto; text-align: center; }
  #sth-meta .m-cta .m-label { font-size: .72rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,.3); display: block; margin-bottom: .5rem; font-family: 'Outfit', system-ui, sans-serif; }
  #sth-meta .m-cta h2 { font-size: clamp(1.65rem, 4vw, 2.25rem); font-weight: 800; color: #fff; line-height: 1.15; margin-bottom: .75rem; font-family: 'Outfit', system-ui, sans-serif; }
  #sth-meta .m-cta h2 em { font-style: normal; color: #C8A96E; }
  #sth-meta .m-cta-sub { font-size: .95rem; color: rgba(255,255,255,.55); line-height: 1.72; margin-bottom: 2rem; font-family: 'Outfit', system-ui, sans-serif; }
  #sth-meta .m-form-card { background: #fff; border-radius: 16px; padding: 2rem; box-shadow: 0 16px 56px rgba(0,0,0,.45); text-align: left; }
  #sth-meta .m-form-card h3 { font-size: 1.15rem; font-weight: 800; margin-bottom: .2rem; color: #1A1A1A; font-family: 'Outfit', system-ui, sans-serif; }
  #sth-meta .m-form-sub { font-size: .82rem; color: #666; margin-bottom: 1.35rem; line-height: 1.5; font-family: 'Outfit', system-ui, sans-serif; }

  /* ── Sticky CTA ── */
  #sth-meta .m-sticky {
    display: none;
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 9999;
    background: #1A1A1A;
    padding: .75rem 1rem;
    padding-bottom: calc(.75rem + env(safe-area-inset-bottom));
    gap: .6rem;
    box-shadow: 0 -4px 24px rgba(0,0,0,.3);
    border-top: 1px solid rgba(255,255,255,.08);
  }
  #sth-meta .m-sticky a { display: block; text-align: center; padding: .9rem 1rem; border-radius: 8px; font-weight: 700; font-size: 1rem; color: #fff; line-height: 1.2; font-family: 'Outfit', system-ui, sans-serif; }
  #sth-meta .m-sc-call { background: #5C6A5B; }
  #sth-meta .m-sc-form { background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.18); }

  @media (max-width: 900px) {
    #sth-meta .m-reviews2-grid { grid-template-columns: 1fr; }
    #sth-meta .m-rev-card      { padding: 1.1rem; }
  }

  @media (max-width: 640px) {
    #sth-meta .m-hero             { min-height: 100svh; background: #1A1A1A; }
    #sth-meta .m-hero-bg          { background-size: 100% auto; background-repeat: no-repeat; background-position: center top; }
    #sth-meta .m-hero-bg::after   {
      background: linear-gradient(to bottom,
        rgba(0,0,0,0) 0%, rgba(0,0,0,0) 30%,
        rgba(0,0,0,.75) 50%, rgba(0,0,0,.92) 100%);
    }
    #sth-meta .m-hero-content     { padding-top: 56vw; padding-left: 1.25rem; padding-right: 1.25rem; }
    #sth-meta .m-hero-cta-wrap    { align-items: stretch; }
    #sth-meta .m-form-card        { padding: 1.5rem; }
    #sth-meta .m-sticky           { display: flex; flex-direction: column; }
    #sth-meta .m-oc               { padding: .85rem .5rem; }
    #sth-meta .m-oc .oc-icon      { font-size: 1.3rem; }
    #sth-meta .m-oc .oc-label     { font-size: .72rem; }
  }
</style>

<LandingLayout
  title="Free Property Assessment — Sunshine Tiny Houses"
  description="Your block could be working for you. Add a granny flat or secondary dwelling — we handle design, council approvals, build and delivery. Free assessment, no obligation."
  noindex={true}
>
  <!-- Meta Pixel -->
  <Fragment slot="head-extra">
    <script is:inline>
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
      n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
      document,'script','https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '1050187050868855');
      fbq('track', 'PageView');
    </script>
    <noscript>
      <img height="1" width="1" style="display:none"
        src="https://www.facebook.com/tr?id=1050187050868855&ev=PageView&noscript=1" />
    </noscript>
  </Fragment>

  <div id="sth-meta">

    <!-- HERO -->
    <section class="m-hero">
      <div class="m-hero-bg" role="img" aria-label="Completed granny flat — Sunshine Tiny Houses Queensland"></div>
      <div class="m-hero-content">
        <span class="m-eyebrow">Sunshine Coast &amp; South East Queensland</span>
        <h1>Your Block Could Be<br><em>Working For You.</em></h1>
        <p class="m-hero-sub">
          A granny flat or secondary dwelling adds space for family, generates rental income,
          and we handle every step &mdash; design, council approvals, build and delivery.
          Factory-built in Noosaville. Turn-key.
        </p>
        <div class="m-hero-cta-wrap">
          <a href="#m-enquire" class="m-btn m-btn-primary">Find Out What&rsquo;s Possible on My Block &rarr;</a>
          <span class="m-hero-reassure">Free. No obligation. Mitch or Nat will be in touch within 24 hours.</span>
        </div>
      </div>
    </section>

    <!-- OUTCOMES -->
    <div class="m-outcomes">
      <div class="m-outcomes-grid">
        <div class="m-oc">
          <span class="oc-icon">&#x1F4B0;</span>
          <span class="oc-label">Rental Income</span>
        </div>
        <div class="m-oc">
          <span class="oc-icon">&#x1F46A;</span>
          <span class="oc-label">Family Space</span>
        </div>
        <div class="m-oc">
          <span class="oc-icon">&#x2705;</span>
          <span class="oc-label">Done For You</span>
        </div>
      </div>
    </div>

    <!-- GALLERY -->
    <section class="m-gallery">
      <div class="m-gallery-intro">
        <span class="m-label">Completed Projects</span>
        <h2>Built in Noosaville. Delivered Across QLD.</h2>
      </div>
      <div class="m-gallery-grid">
        <figure>
          <img src="/images/badge-1.png"
               alt="Completed granny flat exterior" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/workshop-recent-2.jpg"
               alt="Interior finish and fitout" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/workshop-recent-4.jpeg"
               alt="Completed project exterior" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/workshop-recent-3.jpg"
               alt="Completed project" loading="lazy" />
        </figure>
      </div>
    </section>

    <!-- FEATURED REVIEW -->
    <section class="m-review-featured">
      <div class="m-inner m-container">
        <span class="m-stars">&#x2605;&#x2605;&#x2605;&#x2605;&#x2605;</span>
        <blockquote>
          &ldquo;I cannot sing enough praise for Sunshine Tiny Houses. Their product is excellent, their service
          and attention to detail was extraordinary, and we trusted them completely. Such a pleasure
          to do business with and a beautiful home as a final result. They went over and above.
          Highly recommended.&rdquo;
        </blockquote>
        <div class="m-rev-meta">
          <div class="m-avatar">KL</div>
          <div>
            <span class="m-rev-name">Katia L.</span>
            <span class="m-rev-detail">Queensland &middot; Verified Google Review</span>
          </div>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="m-process">
      <div class="m-process-intro">
        <span class="m-label">How It Works</span>
        <h2>Three Steps. We Handle the Rest.</h2>
      </div>
      <div class="m-steps m-container">
        <div class="m-step">
          <div class="m-step-num">1</div>
          <div class="m-step-body">
            <h3>Tell Us About Your Block</h3>
            <p>Fill in the short form below. Mitch or Nat will be in touch within 24 hours with an honest answer about what&rsquo;s possible on your property &mdash; no obligation to go any further.</p>
          </div>
        </div>
        <div class="m-step">
          <div class="m-step-num">2</div>
          <div class="m-step-body">
            <h3>We Design, Quote &amp; Handle Council</h3>
            <p>Custom plans for your block, a clear upfront quote, and we manage all the council approvals and paperwork. You approve everything before a cent is committed.</p>
          </div>
        </div>
        <div class="m-step">
          <div class="m-step-num">3</div>
          <div class="m-step-body">
            <h3>We Build, Deliver &amp; Hand Over the Keys</h3>
            <p>Factory-built in Noosaville, delivered and installed on your property, certified and connected to services. Move-in ready from the day we hand over.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SUPPORTING REVIEWS -->
    <section class="m-reviews2">
      <div class="m-reviews2-grid m-container">
        <div class="m-rev-card">
          <span class="m-stars">&#x2605;&#x2605;&#x2605;&#x2605;&#x2605;</span>
          <blockquote>&ldquo;We had a really positive experience working with the team at Sunshine Tiny Houses. Communication was excellent throughout. They were quick to respond, open to ideas and genuinely invested in making sure everything aligned with what we wanted.&rdquo;</blockquote>
          <div class="m-rev-meta">
            <div class="m-avatar">LW</div>
            <div>
              <span class="m-rev-name">Linda W.</span>
              <span class="m-rev-detail">Google Review</span>
            </div>
          </div>
        </div>
        <div class="m-rev-card">
          <span class="m-stars">&#x2605;&#x2605;&#x2605;&#x2605;&#x2605;</span>
          <blockquote>&ldquo;It was an absolute pleasure working with the team. Nothing was a problem for them. Their attention to detail, input and after-sales service was fantastic. I would highly recommend engaging Sunshine Tiny Houses.&rdquo;</blockquote>
          <div class="m-rev-meta">
            <div class="m-avatar">JS</div>
            <div>
              <span class="m-rev-name">James S.</span>
              <span class="m-rev-detail">Google Review</span>
            </div>
          </div>
        </div>
        <div class="m-rev-card">
          <span class="m-stars">&#x2605;&#x2605;&#x2605;&#x2605;&#x2605;</span>
          <blockquote>&ldquo;Absolutely loved working with Mitch and his team. Communication was always on point, incredibly responsive and full of knowledge. We wouldn&rsquo;t hesitate to have them complete another project for us.&rdquo;</blockquote>
          <div class="m-rev-meta">
            <div class="m-avatar">TC</div>
            <div>
              <span class="m-rev-name">Taleah C.</span>
              <span class="m-rev-detail">Google Review</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA + FORM -->
    <section class="m-cta" id="m-enquire">
      <div class="m-cta-inner">
        <span class="m-label">Free Property Assessment</span>
        <h2>Find Out What&rsquo;s<br><em>Possible on Your Block.</em></h2>
        <p class="m-cta-sub">Takes 30 seconds. Mitch or Nat will be in touch personally within 24 hours &mdash; a straight answer on your property, no sales pitch.</p>

        <div class="m-form-card">
          <h3>Check My Block &rarr;</h3>
          <p class="m-form-sub">Just your name, number, email and location to get started.</p>

          <div id="hs-meta-form"></div>
