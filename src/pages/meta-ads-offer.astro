  <script is:inline>
  (function () {
    'use strict';
    var ENDPOINT = 'https://formsubmit.co/ajax/hello@sunshinetinyhouses.com.au';

    function isValidEmail(v) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim()); }
    function isValidPhone(v) { return v.replace(/[\s\-().+]/g, '').length >= 10; }

    function showError(input, msg) {
      input.classList.add('sth-invalid');
      var err = input.parentNode.querySelector('.sth-field-error');
      if (!err) {
        err = document.createElement('span');
        err.className = 'sth-field-error';
        input.parentNode.appendChild(err);
      }
      err.textContent = msg;
      err.classList.add('sth-visible');
    }
    function clearError(input) {
      input.classList.remove('sth-invalid');
      var err = input.parentNode.querySelector('.sth-field-error');
      if (err) err.classList.remove('sth-visible');
    }
    function validateField(input) {
      var name = input.getAttribute('name');
      var val  = input.value;
      if (name === 'email' && val) {
        if (!isValidEmail(val)) { showError(input, 'Please enter a valid email address.'); return false; }
        else clearError(input);
      }
      if (name === 'phone' && val) {
        if (!isValidPhone(val)) { showError(input, 'Please enter a valid phone number (at least 10 digits).'); return false; }
        else clearError(input);
      }
      return true;
    }

    document.querySelectorAll('.sth-lp-form').forEach(function (form) {
      var submitBtn = form.querySelector('[type="submit"]');

      form.querySelectorAll('input[name="email"], input[name="phone"]').forEach(function (input) {
        input.addEventListener('blur', function () { validateField(input); });
        input.addEventListener('input', function () { if (input.classList.contains('sth-invalid')) validateField(input); });
      });

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var valid = true;
        form.querySelectorAll('input[name="email"], input[name="phone"]').forEach(function (input) {
          if (!validateField(input)) valid = false;
        });
        if (!valid) return;

        var orig = submitBtn.textContent;
        submitBtn.textContent = 'Sending…';
        submitBtn.disabled = true;

        fetch(ENDPOINT, { method: 'POST', body: new FormData(form) })
          .then(function (r) { return r.json(); })
          .then(function (res) {
            if (res.success) {
              if (window.fbq) fbq('track', 'Lead');
              window.location.href = '/contact/thank-you/';
            } else {
              submitBtn.textContent = 'Error — please try again';
              submitBtn.disabled = false;
            }
          })
          .catch(function () {
            submitBtn.textContent = 'Error — please try again';
            submitBtn.disabled = false;
          });
      });
    });

    var heroCard  = document.getElementById('sth-hero-form-card');
    var stickyCta = document.getElementById('sth-sticky-cta');
    if (heroCard && stickyCta && 'IntersectionObserver' in window) {
      new IntersectionObserver(function (entries) {
        stickyCta.style.display = entries[0].isIntersecting ? 'none' : '';
      }, { threshold: 0.05 }).observe(heroCard);
    }
  })();
  </script>

