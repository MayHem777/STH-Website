---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Who are Sunshine Tiny Houses?',
      acceptedAnswer: { '@type': 'Answer', text: 'We are a Queensland licensed building company based in Noosaville on the Sunshine Coast. Our managing director is a Sunshine Coast local with over 20 years of experience working on architectural home builds, renovations and extensions throughout Brisbane and the Sunshine Coast.' },
    },
    {
      '@type': 'Question',
      name: 'What does Sunshine Tiny Houses build?',
      acceptedAnswer: { '@type': 'Answer', text: 'We design and construct custom tiny houses on wheels, modular homes, granny flats, and backyard studios. Builds are available to lock-up, turn-key/complete, or any custom stage.' },
    },
    {
      '@type': 'Question',
      name: 'Is Sunshine Tiny Houses licensed?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes. We hold a current Queensland Builders Licence registered with the QBCC — licence number 15205110. All our tradespeople are qualified, licensed and insured in their respective fields.' },
    },
    {
      '@type': 'Question',
      name: 'Can I visit the Sunshine Tiny Houses factory?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes. Our factory and showroom is located at 24 Venture Drive, Noosaville QLD 4566 and is open Monday–Friday 7:30am–4:00pm and Saturday morning by appointment.' },
    },
    {
      '@type': 'Question',
      name: 'How much does a quote cost?',
      acceptedAnswer: { '@type': 'Answer', text: 'There is no charge for a quote on our standard range. For fully custom builds we charge a design fee — if the build goes ahead, this fee is credited back towards the deposit.' },
    },
    {
      '@type': 'Question',
      name: 'How much does a tiny house cost?',
      acceptedAnswer: { '@type': 'Answer', text: 'Lock-up tiny houses start from around $45,000–$50,000. Turn-key builds start from $85,000–$95,000 depending on size, layout and inclusions. Contact us for a detailed quote.' },
    },
    {
      '@type': 'Question',
      name: 'How long does the build take?',
      acceptedAnswer: { '@type': 'Answer', text: 'It typically takes several weeks to a month to finalise your design. We then order your trailer, windows and frames, which take 4–6 weeks to arrive. Once materials arrive, we complete your home in 6–12 weeks depending on complexity.' },
    },
    {
      '@type': 'Question',
      name: 'What is the payment schedule for a tiny house on wheels?',
      acceptedAnswer: { '@type': 'Answer', text: 'Payment is in five 20% instalments: on deposit to secure your build slot, on arrival of your trailer, on completion of the frame, on completion of interior painting, and a final payment on completion prior to delivery.' },
    },
    {
      '@type': 'Question',
      name: 'Do you offer finance for tiny houses?',
      acceptedAnswer: { '@type': 'Answer', text: "Yes. We've partnered with Emu Money and Handypay to offer competitive finance options for tiny houses and modular homes." },
    },
    {
      '@type': 'Question',
      name: 'Do you deliver tiny houses across Queensland?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes. We work with a network of experienced and insured delivery contractors across Australia. Delivery is quoted on a case-by-case basis.' },
    },
    {
      '@type': 'Question',
      name: 'What is a tiny house on wheels?',
      acceptedAnswer: { '@type': 'Answer', text: 'Tiny houses on wheels (THOWs) are compact, fully-functional dwellings built on a trailer chassis, allowing them to be mobile and transported. They typically range from 9 to 37 square metres and offer all the essentials of a traditional home in a cleverly designed, space-efficient package.' },
    },
    {
      '@type': 'Question',
      name: 'Do I need council approval for a tiny house in Queensland?',
      acceptedAnswer: { '@type': 'Answer', text: 'It depends on your council and how long you intend to stay. Most councils treat tiny houses as caravans and allow short-term stays without a permit. Longer-term arrangements may require a permit. Regulations vary significantly between councils — see our Council Regulations page or contact your local council for current rules.' },
    },
    {
      '@type': 'Question',
      name: 'What are the maximum dimensions for a tiny house on wheels?',
      acceptedAnswer: { '@type': 'Answer', text: 'Maximum dimensions are set by transport regulations: 4.3m high, 2.5m wide, and 12.5m long including draw bar. Our largest standard model is 9m plus the draw bar.' },
    },
    {
      '@type': 'Question',
      name: 'Can I have more than one tiny house on my property?',
      acceptedAnswer: { '@type': 'Answer', text: 'This may require a development application, as it could be considered a dual occupancy or multiple dwelling under your planning scheme. A planning consultant can advise on your specific property and council area.' },
    },
    {
      '@type': 'Question',
      name: 'Where can I park my tiny house?',
      acceptedAnswer: { '@type': 'Answer', text: 'The ideal scenario is parking on your own property. Other options include renting a serviced or un-serviced plot, tiny house communities, and caravan parks that allow permanent living. Rules vary by location.' },
    },
    {
      '@type': 'Question',
      name: 'What is a modular home?',
      acceptedAnswer: { '@type': 'Answer', text: 'A modular home is a compact living space prefabricated in our Noosaville factory and delivered ready for use. Our modular homes are classified as Class 1A dwellings and can serve as granny flats, studios, or secondary dwellings.' },
    },
    {
      '@type': 'Question',
      name: 'Are modular homes suitable as granny flats in Queensland?',
      acceptedAnswer: { '@type': 'Answer', text: 'Absolutely. Modular homes are excellent for granny flats, home offices, creative studios, or additional family accommodation. Each council has its own regulations regarding granny flat sizes and zoning.' },
    },
    {
      '@type': 'Question',
      name: 'How long does a modular home take from design to delivery?',
      acceptedAnswer: { '@type': 'Answer', text: 'Typically 16–22 weeks depending on size, complexity, customisation, permitting and delivery location.' },
    },
    {
      '@type': 'Question',
      name: 'What is the payment schedule for a modular home?',
      acceptedAnswer: { '@type': 'Answer', text: 'Payment is in seven stages: 5% on contract signing, 15% on certified completion of the engineered floor system, 25% on certified completion of framing, 10% on completion of interior painting, 20% at lock-up stage, 20% on completion of building works prior to leaving the factory, and a final 5% at handover.' },
    },
    {
      '@type': 'Question',
      name: 'Can I customise my tiny house or modular home?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes. We design everything in-house — initial concepts, 3D renders and working drawings including cabinetry. We can modify any standard plan or design a completely custom build to your specifications.' },
    },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.sunshinetinyhouses.com.au/' },
    { '@type': 'ListItem', position: 2, name: 'FAQ', item: 'https://www.sunshinetinyhouses.com.au/faq/' },
  ],
};
---

<BaseLayout
  title="Tiny House & Modular Home FAQ | Sunshine Tiny Houses"
  description="Answers to common questions about tiny houses on wheels, modular homes, council approvals, finance, delivery and more — from Sunshine Tiny Houses, QLD."
  canonical="https://www.sunshinetinyhouses.com.au/faq/"
  schema={[faqSchema, breadcrumbSchema]}
>

  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Got Questions?</p>
      <h1>Frequently Asked Questions</h1>
      <p class="page-hero__sub">Everything you need to know — about us, our builds, and tiny house living.</p>
    </div>
  </section>

  <section class="section">
    <div class="container faq-wrap">

      <div class="faq-group">
        <h2>About Sunshine Tiny Houses</h2>

        <details class="faq-item">
          <summary><h3>Who are Sunshine Tiny Houses?</h3></summary>
          <p>We are a Queensland licensed building company based in Noosaville on the Sunshine Coast. Our managing director is a Sunshine Coast local with over 20 years of experience working on architectural home builds, renovations and extensions throughout Brisbane and the Sunshine Coast. You can rest assured that your build will be constructed with the skills and knowledge required to make a safe and durable home.</p>
        </details>

        <details class="faq-item">
          <summary><h3>What does Sunshine Tiny Houses build?</h3></summary>
          <p>We design and construct custom tiny houses on wheels, modular homes, granny flats, and backyard studios. We work closely with our clients, designers and contractors to achieve the perfect layout to suit your specific needs. Builds are available to three stages:</p>
          <ul>
            <li><strong>Lock-up</strong> — Structure is watertight with windows, roofing and cladding installed. Interior is bare frames requiring electrical, plumbing, linings, joinery and painting.</li>
            <li><strong>Turn-key / Complete</strong> — Completely finished and ready to move in and enjoy.</li>
            <li><strong>Custom</strong> — We can complete to any stage you'd like. Get in touch to discuss.</li>
          </ul>
        </details>

        <details class="faq-item">
          <summary><h3>Is the business licensed?</h3></summary>
          <p>Yes. We hold a current Queensland Builders Licence registered with the QBCC — licence number 15205110. All our tradespeople are qualified, licensed and insured in their respective fields.</p>
        </details>

        <details class="faq-item">
          <summary><h3>Can I visit your factory?</h3></summary>
          <p>Yes. Our factory and showroom is located at 24 Venture Drive, Noosaville QLD 4566 and is open Monday–Friday 7:30am–4:00pm and Saturday morning by appointment. Give us a call or book online so we can free up time to show you around and chat about your project.</p>
        </details>

        <details class="faq-item">
          <summary><h3>How much does a quote cost?</h3></summary>
          <p>There is no charge for a quote on our standard range. For fully custom builds we charge a design fee to consult and create your plans — if the build goes ahead, this fee is credited back towards the deposit.</p>
        </details>

        <details class="faq-item">
          <summary><h3>How much does a tiny house cost?</h3></summary>
          <p>Lock-up tiny houses start from around $45,000–$50,000. Turn-key builds start from $85,000–$95,000 depending on size, layout and inclusions. Contact us for a detailed quote on your specific requirements.</p>
        </details>

        <details class="faq-item">
          <summary><h3>How long does the build take?</h3></summary>
          <p>It typically takes several weeks to a month to finalise your design depending on complexity. We then order your trailer, windows and frames, which take 4–6 weeks to arrive. Once materials arrive, we anticipate completing your home in 6–12 weeks depending on complexity. Supply chain lead times can affect timelines.</p>
        </details>

        <details class="faq-item">
          <summary><h3>Do you offer finance?</h3></summary>
          <p>Yes. We've partnered with Emu Money and Handypay to offer competitive finance options. See our <a href="/finance/">Finance page</a> for details.</p>
        </details>

        <details class="faq-item">
          <summary><h3>Do you offer delivery?</h3></summary>
          <p>Yes. We work with a network of experienced and insured delivery contractors across Australia. Delivery is quoted on a case-by-case basis. See our <a href="/delivery/">Delivery page</a> for more information.</p>
        </details>
      </div>

      <div class="faq-group">
        <h2>About Modular Homes</h2>

        <details class="faq-item">
          <summary><h3>What is a modular home?</h3></summary>
          <p>A modular home is a compact living space designed for simplicity and efficiency. Prefabricated off-site in our Noosaville factory, it's delivered ready for use. Our modular homes are classified as Class 1A dwellings and can serve as granny flats, studios, or secondary dwellings.</p>
        </details>

        <details class="faq-item">
          <summary><h3>What are the advantages of a modular home over traditional construction?</h3></summary>
          <p>Modular homes are built in our factory, which greatly reduces on-site disruption. The entire on-site process requires only two weeks on your property — one week before delivery for site preparation, and one week after for connections. This means a quicker build, less stress, and a more predictable outcome compared to traditional construction.</p>
        </details>

        <details class="faq-item">
          <summary><h3>How long does a modular home take from design to delivery?</h3></summary>
          <p>Typically 16–22 weeks depending on size, complexity, customisation, permitting and delivery location.</p>
        </details>

        <details class="faq-item">
          <summary><h3>What is the payment schedule for a modular home?</h3></summary>
          <ul>
            <li>5% Payable upon acceptance of the quotation and execution of the building contract</li>
            <li>15% Due upon completion of the engineered floor system, following certification by our structural engineer</li>
            <li>25% Payable upon completion of the framing stage, once certified by our structural engineer</li>
            <li>10% Payable on completion of interior painting</li>
            <li>20% Due at the lock-up stage, defined as the installation of external doors and windows, and completion of external cladding (unpainted)</li>
            <li>20% Payable upon completion of the building works and prior to the unit departing our factory</li>
            <li>5% Final payment due at handover, following the completion of all finishing details and any applicable on-site works</li>
          </ul>
        </details>

        <details class="faq-item">
          <summary><h3>What foundation do modular homes need?</h3></summary>
          <p>Modular homes require a stable, level foundation — typically a concrete slab or screw piles. The specific type is determined by soil testing. We manage site preparation as part of the process.</p>
        </details>

        <details class="faq-item">
          <summary><h3>Are modular homes suitable as granny flats?</h3></summary>
          <p>Absolutely. Modular homes are excellent for granny flats, creative studios, home offices, or additional family accommodation. Keep in mind each council has its own regulations regarding granny flat sizes and zoning — call Mitch and Nat for personalised guidance on your property.</p>
        </details>
      </div>

      <div class="faq-group">
        <h2>About Tiny Houses</h2>

        <details class="faq-item">
          <summary><h3>What is a tiny house on wheels?</h3></summary>
          <p>Tiny houses on wheels (THOWs) are compact, fully-functional dwellings built on a trailer chassis, allowing them to be mobile and transported. They typically range from 9 to 37 square metres and offer all the essentials of a traditional home — living area, kitchen, bathroom and sleeping quarters — in a cleverly designed, space-efficient package.</p>
        </details>

        <details class="faq-item">
          <summary><h3>Why are tiny houses on wheels?</h3></summary>
          <p>Tiny houses on wheels offer the freedom and flexibility of a mobile lifestyle without compromising on comfort. The smaller footprint makes relocation easy, and the wheeled design can circumvent certain zoning regulations, providing a creative solution for those seeking a sustainable, minimalist lifestyle.</p>
        </details>

        <details class="faq-item">
          <summary><h3>What is the payment schedule for a tiny house on wheels?</h3></summary>
          <ul>
            <li>20% Deposit to secure your build slot — we order your trailer and windows/doors</li>
            <li>20% Progress payment on arrival of your trailer</li>
            <li>20% Progress payment on completion of the frame</li>
            <li>20% Progress payment on completion of interior painting</li>
            <li>20% Final payment on completion, prior to delivery</li>
          </ul>
        </details>

        <details class="faq-item">
          <summary><h3>Is a tiny house the same as a secondary dwelling?</h3></summary>
          <p>Not exactly. A secondary dwelling is a self-contained space located on the same property as a primary residence — typically larger and on a fixed foundation. A tiny house can be used as a secondary dwelling but is generally smaller, often on wheels, and can be relocated. Both can provide affordable housing options and additional living space on a property.</p>
        </details>

        <details class="faq-item">
          <summary><h3>What are the maximum dimensions for a tiny house?</h3></summary>
          <p>Maximum dimensions are set by transport regulations: 4.3m high, 2.5m wide, and 12.5m long (including draw bar). Our largest standard model is 9m plus the draw bar. Builds larger than 9m can be constructed but cannot be towed on public roads and must be transported by low loader.</p>
        </details>

        <details class="faq-item">
          <summary><h3>Do I need council approval for a tiny house?</h3></summary>
          <p>It depends on your council and how long you intend to stay. Most councils treat tiny houses as caravans and allow short-term stays without a permit. Longer-term arrangements may require a permit or approval. Regulations vary significantly between councils and states — see our <a href="/council-regulations/">Council Regulations page</a> or contact your local council directly for current rules.</p>
        </details>

        <details class="faq-item">
          <summary><h3>What authorisations do I need?</h3></summary>
          <p>Under the Planning Act 2016 and Building Act 1975, tiny houses are "assessable development" and require a building and plumbing permit, similar to a conventional dwelling. If your tiny house doesn't meet all dwelling code requirements, a planning approval from council may also be required. We recommend speaking with a private building certifier or planning consultant for your specific situation.</p>
        </details>

        <details class="faq-item">
          <summary><h3>Can I have more than one tiny house on my property?</h3></summary>
          <p>This may require a development application, as it could be considered a dual occupancy or multiple dwelling under your planning scheme. If you intend to use the property for short-term accommodation, additional approvals may also be triggered. A planning consultant can advise on your specific property and council area.</p>
        </details>

        <details class="faq-item">
          <summary><h3>Where can I park my tiny house?</h3></summary>
          <p>The ideal scenario is parking on your own property. Other options include renting a serviced or un-serviced plot, tiny house communities, and caravan parks that allow permanent living. Rules vary by location — contact your local council for current regulations.</p>
        </details>

        <details class="faq-item">
          <summary><h3>Can I tow my tiny house?</h3></summary>
          <p>Yes, if your vehicle can tow the weight of your model. You'll need to have your tiny house registered or obtain a temporary vehicle permit for the duration of any move.</p>
        </details>

        <details class="faq-item">
          <summary><h3>How do I connect electricity, water and gas?</h3></summary>
          <ul>
            <li><strong>Electricity (grid):</strong> Plug a 15-amp lead into the 15-amp input under your trailer and into a nearby 15-amp outlet.</li>
            <li><strong>Water:</strong> Connect a food-grade garden hose to the ¼-turn ball valve water input on your draw bar — from a mains tap or a tank-fed pump. Can also be hard-plumbed.</li>
            <li><strong>Gas:</strong> We use a dual-connection LPG regulator — connect up to two bottles at once and flip the lever when one runs out. We recommend 9kg or 4kg bottles.</li>
          </ul>
        </details>
      </div>

      <div class="faq-group">
        <h2>Customisation</h2>

        <details class="faq-item">
          <summary><h3>Can I customise my tiny house or modular home?</h3></summary>
          <p>Yes. We design everything in-house, including initial concepts, 3D renders and working drawings including cabinetry design and layout. We're happy to talk through your ideas and help you achieve your vision, or you can take one of our standard range plans and modify it to your heart's content.</p>
        </details>

        <details class="faq-item">
          <summary><h3>Can I customise my cabinetry?</h3></summary>
          <p>Yes. You can come to our office and sit with our design team to fine-tune your cabinet design, materials and finishes.</p>
        </details>
      </div>

      <div class="faq-cta">
        <p>Still have questions?</p>
        <a href="/contact/" class="btn btn--primary">Get in Touch</a>
        <a href="tel:0753158365" class="btn btn--outline">(07) 5315 8365</a>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
.page-hero {
  background: var(--color-surface-dark);
  color: #fff;
  padding: 4rem 0 3rem;
}
.page-hero h1 { color: #fff; }
.page-hero__sub { color: rgba(255,255,255,.7); margin-top: .75rem; font-size: 1.1rem; max-width: 560px; }

.faq-wrap { max-width: 860px; }

.faq-group { margin-bottom: 3.5rem; }
.faq-group h2 { margin-bottom: 1.75rem; padding-bottom: .75rem; border-bottom: 2px solid var(--color-border); }

.faq-item { margin-bottom: .75rem; padding-bottom: .75rem; border-bottom: 1px solid var(--color-border); }
.faq-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }

.faq-item summary {
  list-style: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: .6rem 0;
  -webkit-tap-highlight-color: transparent;
}
.faq-item summary::-webkit-details-marker { display: none; }
.faq-item summary::marker { content: ''; }

.faq-item summary h3 { font-size: 1rem; margin: 0; color: var(--color-text); }

.faq-item summary::after {
  content: '';
  flex-shrink: 0;
  width: .55rem;
  height: .55rem;
  border-right: 2px solid var(--color-primary);
  border-bottom: 2px solid var(--color-primary);
  transform: rotate(45deg);
  transition: transform .2s ease;
  margin-top: -.2rem;
}
.faq-item[open] summary::after { transform: rotate(-135deg); margin-top: .2rem; }

.faq-item summary:hover h3 { color: var(--color-primary); }
.faq-item summary:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 4px; border-radius: 4px; }

.faq-item > p, .faq-item > ul { padding-top: .2rem; padding-bottom: .6rem; }
.faq-item p { color: var(--color-text-body); }
.faq-item p + p { margin-top: .6rem; }
.faq-item ul { padding-left: 1.25rem; display: flex; flex-direction: column; gap: .4rem; }
.faq-item ul li { color: var(--color-text-body); font-size: .95rem; line-height: 1.65; }
.faq-item a { color: var(--color-primary); text-decoration: underline; text-underline-offset: 2px; }

@media (prefers-reduced-motion: reduce) {
  .faq-item summary::after { transition: none; }
}

.faq-cta { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; padding-top: 2rem; border-top: 2px solid var(--color-border); }
.faq-cta p { font-weight: 700; color: var(--color-text); margin: 0; }

.btn {
  display: inline-block;
  padding: .8rem 1.75rem;
  border-radius: 8px;
  font-weight: 700;
  font-size: .95rem;
  font-family: var(--font-heading);
  cursor: pointer;
  transition: background .2s, transform .15s;
  text-align: center;
}
.btn--primary { background: var(--color-primary); color: #fff; }
.btn--primary:hover { background: var(--color-primary-hover); transform: translateY(-2px); }
.btn--outline { background: transparent; color: var(--color-primary); border: 2px solid var(--color-primary); }
.btn--outline:hover { background: var(--color-primary); color: #fff; }
</style>
