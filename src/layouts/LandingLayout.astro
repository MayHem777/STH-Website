---
import SEOHead from '../components/SEOHead.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
  canonical?: string;
}

const { title, description, noindex = true, canonical } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead {title} {description} {noindex} {canonical} />
    <slot name="head-extra" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>

    <header class="lp-header">
      <div class="lp-header__inner">
        <a href="/" aria-label="Sunshine Tiny Houses — home">
          <img
            src="https://images.squarespace-cdn.com/content/v1/63f446dc343cd34fe798c868/e858209c-0eb1-4a4f-9df5-2beb53f5ef8e/logo.png"
            alt="Sunshine Tiny Houses"
            height="44"
            loading="eager"
          />
        </a>
        <a href="tel:0753158365" class="lp-phone">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.84a16 16 0 0 0 6.29 6.29l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (07) 5315 8365
        </a>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="lp-footer">
      <div class="lp-footer__inner">
        <p>© Sunshine Tiny Houses 2025 &nbsp;·&nbsp; QBCC #15205110 &nbsp;·&nbsp; ABN 40 270 427 080</p>
        <p><a href="/privacy-policy/">Privacy Policy</a></p>
      </div>
    </footer>
  </body>
</html>

<style>
.skip-link {
  position: absolute;
  left: -9999px;
  top: auto;
  width: 1px;
  height: 1px;
  overflow: hidden;
}
.skip-link:focus {
  position: static;
  width: auto;
  height: auto;
}

.lp-header {
  background: var(--color-bg);
  border-bottom: 1px solid var(--color-border);
  position: sticky;
  top: 0;
  z-index: 100;
}
.lp-header__inner {
  max-width: var(--container-max);
  margin: 0 auto;
  padding: 0 var(--spacing-container);
  height: auto;
  min-height: 64px;
  padding-top: .85rem;
  padding-bottom: .85rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.lp-header img {
  display: block;
  height: 120px;
  width: auto;
}
@media (max-width: 640px) {
  .lp-header img { height: 50px; }
}
.lp-phone {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-weight: 700;
  font-size: var(--font-size-base);
  color: var(--color-primary);
  white-space: nowrap;
}
.lp-phone:hover {
  color: var(--color-primary-hover);
}

.lp-footer {
  background: var(--color-surface-dark);
  color: rgba(255,255,255,0.55);
  padding: 1.5rem var(--spacing-container);
  margin-top: 4rem;
}
.lp-footer__inner {
  max-width: var(--container-max);
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.5rem;
  font-size: var(--font-size-sm);
}
.lp-footer a {
  color: rgba(255,255,255,0.55);
}
.lp-footer a:hover {
  color: #fff;
}
</style>
