---
const PRODUCT_LINKS = [
  { label: 'Tiny Houses on Wheels', href: '/tiny-houses-on-wheels/' },
  { label: 'Modular Homes & Granny Flats', href: '/modular-homes/' },
  { label: 'Backyard Studios', href: '/backyard-studios/' },
  { label: 'Custom Design & Build', href: '/tiny-houses-on-wheels/custom-design-build/' },
  { label: 'Trailers', href: '/tiny-houses-on-wheels/trailers/' },
];

const INFO_LINKS = [
  { label: 'About Us', href: '/about/' },
  { label: "FAQ's", href: '/faq/' },
  { label: 'Finance', href: '/finance/' },
  { label: 'Delivery', href: '/delivery/' },
  { label: 'Off Grid', href: '/off-grid/' },
  { label: 'Council Regulations', href: '/council-regulations/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Gallery', href: '/gallery/' },
];

const year = new Date().getFullYear();
---

<footer class="site-footer section--dark">
  <div class="container">
    <div class="footer-grid">

      <div class="footer-brand">
        <a href="/" aria-label="Sunshine Tiny Houses — home">
          <img
            src="/images/logo.png"
            alt="Sunshine Tiny Houses"
            width="160"
            height="54"
            loading="lazy"
            style="filter: brightness(0) invert(1);"
          />
        </a>
        <p class="footer-tagline">Queensland's trusted tiny home builder.</p>
        <address class="footer-contact">
          <p>24 Venture Drive, Noosaville QLD 4566</p>
          <p><a href="tel:+61753158365">(07) 5315 8365</a></p>
          <p><a href="mailto:hello@sunshinetinyhouses.com.au">hello@sunshinetinyhouses.com.au</a></p>
        </address>
        <div class="footer-socials">
          <a href="https://www.instagram.com/sunshinetinyhouses" aria-label="Instagram" rel="noopener noreferrer" target="_blank">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="https://www.facebook.com/sunshinetinyhouses" aria-label="Facebook" rel="noopener noreferrer" target="_blank">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://www.youtube.com/@SunshineTinyHouses" aria-label="YouTube" rel="noopener noreferrer" target="_blank">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="footer-nav">
        <h3 class="footer-heading">Products</h3>
        <ul role="list">
          {PRODUCT_LINKS.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </div>

      <div class="footer-nav">
        <h3 class="footer-heading">Information</h3>
        <ul role="list">
          {INFO_LINKS.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </div>

      <div class="footer-cta-col">
        <h3 class="footer-heading">Get Started</h3>
        <p>Ready to build your dream tiny home? Get a free, no-obligation quote today.</p>
        <a href="/contact/" class="btn-footer-cta">Contact Now</a>
        <div class="footer-badges">
          <img
            src="/images/qbcc-open.png"
            alt="QBCC Licensed Builder #15205110"
            width="80"
            height="80"
            loading="lazy"
          />
          <img
            src="/images/tha-round.webp"
            alt="Tiny Home Association member"
            width="80"
            height="80"
            loading="lazy"
          />
        </div>
      </div>

    </div>

    <div class="footer-bottom">
      <p>ABN 40 270 427 080 | QBCC Licence #15205110</p>
      <p>&copy; {year} Sunshine Tiny Houses. All rights reserved. <a href="/privacy-policy/">Privacy Policy</a></p>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background-color: var(--color-surface-dark);
  color: var(--color-text-on-dark);
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1.5fr;
  gap: 3rem;
  padding-block: 4rem 2rem;
}

.footer-brand .footer-tagline {
  margin-top: 1rem;
  font-size: var(--font-size-sm);
  opacity: 0.75;
}

.footer-contact {
  margin-top: 1rem;
  font-style: normal;
  font-size: var(--font-size-sm);
  line-height: 1.8;
  opacity: 0.85;
}
.footer-contact a:hover {
  opacity: 1;
  color: var(--color-accent);
}

.footer-socials {
  display: flex;
  gap: 1rem;
  margin-top: 1.25rem;
}
.footer-socials a {
  opacity: 0.7;
  transition: opacity var(--transition-fast), color var(--transition-fast);
}
.footer-socials a:hover {
  opacity: 1;
  color: var(--color-accent);
}

.footer-heading {
  font-size: var(--font-size-sm);
  font-family: var(--font-body);
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: 1rem;
}

.footer-nav ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.footer-nav a {
  font-size: var(--font-size-sm);
  opacity: 0.8;
  transition: opacity var(--transition-fast), color var(--transition-fast);
}
.footer-nav a:hover {
  opacity: 1;
  color: var(--color-accent);
}

.footer-cta-col p {
  font-size: var(--font-size-sm);
  opacity: 0.8;
  margin-bottom: 1.25rem;
  line-height: 1.6;
}

.btn-footer-cta {
  display: inline-block;
  padding: 0.75rem 2rem;
  background-color: var(--color-accent);
  color: #fff;
  font-size: var(--font-size-sm);
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  border-radius: var(--radius-btn);
  transition: opacity var(--transition-fast);
}
.btn-footer-cta:hover {
  opacity: 0.9;
}

.footer-badges {
  display: flex;
  gap: 1rem;
  margin-top: 1.5rem;
  align-items: center;
}
.footer-badges img {
  opacity: 0.9;
  filter: brightness(0) invert(1);
}

.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.1);
  padding-block: 1.5rem;
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.5rem;
  font-size: var(--font-size-xs);
  opacity: 0.6;
}
.footer-bottom a:hover {
  opacity: 1;
  text-decoration: underline;
}

@media (max-width: 960px) {
  .footer-grid {
    grid-template-columns: 1fr 1fr;
  }
  .footer-brand {
    grid-column: 1 / -1;
  }
}

@media (max-width: 600px) {
  .footer-grid {
    grid-template-columns: 1fr;
  }
  .footer-bottom {
    flex-direction: column;
  }
}
</style>
