---
const NAV = [
  { label: 'Tiny Houses on Wheels', href: '/tiny-houses-on-wheels/' },
  { label: 'Modular Homes', href: '/modular-homes/' },
  { label: 'Backyard Studios', href: '/backyard-studios/' },
  {
    label: 'Things to Know',
    children: [
      { label: 'Finance', href: '/finance/' },
      { label: 'Delivery', href: '/delivery/' },
      { label: 'Off Grid', href: '/off-grid/' },
      { label: 'Council Regulations', href: '/council-regulations/' },
    ],
  },
  { label: 'About', href: '/about/' },
  { label: "FAQ's", href: '/faq/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Gallery', href: '/gallery/' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo-link" aria-label="Sunshine Tiny Houses — home">
      <img
        src="/images/logo.png"
        alt="Sunshine Tiny Houses"
        loading="eager"
        fetchpriority="high"
      />
    </a>

    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="primary-nav">
      <span></span><span></span><span></span>
    </button>

    <nav id="primary-nav" class="primary-nav" aria-label="Primary navigation">
      <ul class="nav-list" role="list">
        {NAV.map((item) => (
          item.children ? (
            <li class="nav-item nav-item--dropdown">
              <button class="nav-link nav-dropdown-toggle" aria-expanded="false">
                {item.label}
                <svg class="chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
                  <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                </svg>
              </button>
              <ul class="dropdown" role="list">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class:list={['dropdown-link', { 'is-active': currentPath === child.href }]}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          ) : (
            <li class="nav-item">
              <a
                href={item.href}
                class:list={['nav-link', { 'is-active': currentPath === item.href }]}
              >
                {item.label}
              </a>
            </li>
          )
        ))}
      </ul>
      <a href="/contact/" class="btn btn--primary nav-cta">Contact Now</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const nav = document.querySelector<HTMLElement>('#primary-nav');
  const dropdownToggles = document.querySelectorAll<HTMLButtonElement>('.nav-dropdown-toggle');

  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  });

  dropdownToggles.forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      dropdownToggles.forEach((b) => b.setAttribute('aria-expanded', 'false'));
      btn.setAttribute('aria-expanded', String(!expanded));
    });
  });

  document.addEventListener('click', (e) => {
    if (!(e.target as Element)?.closest('.nav-item--dropdown')) {
      dropdownToggles.forEach((b) => b.setAttribute('aria-expanded', 'false'));
    }
  });
</script>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: var(--color-bg);
  border-bottom: 1px solid var(--color-border);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
  height: 72px;
}

.logo-link {
  flex-shrink: 0;
}
.logo-link img {
  display: block;
  height: auto;
  max-height: 52px;
  width: auto;
}

.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.5rem;
}
.nav-toggle span {
  display: block;
  width: 24px;
  height: 2px;
  background-color: var(--color-text);
  border-radius: 2px;
  transition: transform var(--transition-fast);
}

.primary-nav {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.nav-list {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  list-style: none;
}

.nav-link {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  padding: 0.5rem 0.75rem;
  font-size: var(--font-size-sm);
  font-weight: 500;
  color: var(--color-text);
  border-radius: var(--radius-btn);
  background: none;
  border: none;
  cursor: pointer;
  transition: color var(--transition-fast);
  white-space: nowrap;
}
.nav-link:hover,
.nav-link.is-active {
  color: var(--color-primary);
}

.nav-item--dropdown {
  position: relative;
}
.chevron {
  transition: transform var(--transition-fast);
}
[aria-expanded="true"] .chevron {
  transform: rotate(180deg);
}

.dropdown {
  display: none;
  position: absolute;
  top: calc(100% + 0.5rem);
  left: 0;
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  list-style: none;
  min-width: 200px;
  padding: 0.5rem 0;
}
[aria-expanded="true"] + .dropdown {
  display: block;
}
.dropdown-link {
  display: block;
  padding: 0.625rem 1.25rem;
  font-size: var(--font-size-sm);
  white-space: nowrap;
  transition: color var(--transition-fast), background-color var(--transition-fast);
}
.dropdown-link:hover,
.dropdown-link.is-active {
  color: var(--color-primary);
  background-color: var(--color-surface);
}

.nav-cta {
  margin-left: 0.5rem;
}

.btn {
  display: inline-block;
  padding: 0.625rem 1.5rem;
  border-radius: var(--radius-btn);
  font-size: var(--font-size-sm);
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}
.btn--primary {
  background-color: var(--color-primary);
  color: #fff;
}
.btn--primary:hover {
  background-color: var(--color-primary-hover);
}

@media (max-width: 960px) {
  .nav-toggle {
    display: flex;
  }

  .primary-nav {
    display: none;
    flex-direction: column;
    align-items: flex-start;
    position: absolute;
    top: 72px;
    left: 0;
    right: 0;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem;
    gap: 0;
  }
  .primary-nav.is-open {
    display: flex;
  }
  .nav-list {
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
    gap: 0;
  }
  .nav-item {
    width: 100%;
  }
  .nav-link {
    width: 100%;
    padding: 0.75rem 0.5rem;
  }
  .dropdown {
    position: static;
    box-shadow: none;
    border: none;
    border-left: 2px solid var(--color-border);
    margin-left: 1rem;
    border-radius: 0;
  }
  .nav-cta {
    margin-left: 0;
    margin-top: 1rem;
  }
}
</style>
